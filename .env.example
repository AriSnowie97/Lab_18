# Telegram бот
BOT_TOKEN=your_telegram_bot_token_here

# OpenWeatherMap
WEATHER_API_KEY=your_openweathermap_api_key_here

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Redis (Railway підставляє REDIS_URL автоматично при підключенні плагіна)
REDIS_URL=redis://localhost:6379

# Mini App (URL де задеплоєно статику — той самий Railway web сервіс)
MINIAPP_URL=https://your-app.railway.app

# CORS (через кому, або * для всіх)
ALLOWED_ORIGINS=https://your-app.railway.app
